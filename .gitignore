!inst/app/www/*.png
!inst/app/www/*.svg
!inst/app/www/*.jpg

# Editor / OS
.DS_Store
.idea/
.vscode/
.claude/

# shinylive build artifacts (built in CI, not checked in)
site/
_app/

# Renv (optional)
renv/library/
renv/python/
renv/staging/

# Packrat (legacy)
packrat/lib*/

# Python launcher byproducts
__pycache__/
*.pyc
